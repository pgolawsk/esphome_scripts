extends: default
rules:
  line-length: disable
  key-duplicates: disable
  truthy:
    check-keys: false
  indentation:
    indent-sequences: whatever
  # Allow `!include { file: ..., vars: { ... } }` and `vars: { }` per AGENTS.md "Include Patterns"
  braces:
    max-spaces-inside: 1
    max-spaces-inside-empty: 1
