# Symlinks point into machine-local .venv — do not commit them.
# Only the patched header(s) under KEEP_LOCAL in refresh.sh are
# version-controlled. The .upstream snapshot files are local-only
# drift detectors created by refresh.sh.

esphome/components/esp32/*
!esphome/components/esp32/preferences.h
!esphome/components/esp32/preference_backend.h
esphome/components/esp32/.*.upstream
