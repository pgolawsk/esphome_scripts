# ESPHome project aliases - loaded automatically by zsh (.zshrc.local)
# Pawelo, 20251225, created for directory-scoped aliases for ESPHome projects
# Pawelo, 20260209, added dev aliases for testing with dev yaml files and prod aliases for production yaml files, both with the same device name and parameters, but different yaml files (0_DEV vs 2_PROD)
# FLUX, 20260511, slimmed aliases — substitution defaults now live in device YAMLs (BACKLOG item 25). Override per-flash with `-s key value` only if you want a non-default value.

alias esp05='esphome run 2_PROD/esp32-05_Shades_WinterGardenUpp.yaml --device esp32-05.lan'
alias esp06='esphome run 2_PROD/esp32-06_Garden_Gateway.yaml --device esp32-06.lan'
alias esp10='esphome run 2_PROD/esp12f-10_Office.yaml --device esp12f-10.lan'
alias esp11='esphome run 2_PROD/esp12f-11_Entrance_Entry.yaml --device esp12f-11.lan'
alias esp14='esphome run 2_PROD/esp32-14_Salon.yaml --device esp32-14.lan'
alias esp15='esphome run 2_PROD/esp12f-15_Upstairs.yaml --device esp12f-15.lan'
alias esp21='esphome run 2_PROD/esp12f-21_Underfloor.yaml --device esp12f-21.lan'
alias esp25='esphome run 2_PROD/esp12f-25_AquariumWindow.yaml --device esp12f-25.lan'
alias esp35='esphome run 2_PROD/esp32-35_Pump_Garage.yaml --device esp32-35.lan'
alias esp36='esphome run 2_PROD/esp32-36_Garage_Gate.yaml --device esp32-36.lan'
alias esp39='esphome run 2_PROD/esp32-39_Attic.yaml --device esp32-39.lan'

# DEV aliases — only esp05dev and esp35dev point at existing files; other dev YAMLs do not exist (broken aliases retained for parity, will fail with "file not found" until DEV YAMLs are created).
alias esp05dev='esphome run 0_DEV/esp32-05_Shades_WinterGardenUpp.yaml --device esp32-05.lan'
alias esp06dev='esphome run 0_DEV/esp32-06_Garden_Gateway.yaml --device esp32-06.lan'
alias esp10dev='esphome run 0_DEV/esp12f-10_Office.yaml --device esp12f-10.lan'
alias esp11dev='esphome run 0_DEV/esp12f-11_Entrance_Entry.yaml --device esp12f-11.lan'
alias esp14dev='esphome run 0_DEV/esp32-14_Salon.yaml --device esp32-14.lan'
alias esp15dev='esphome run 0_DEV/esp12f-15_Upstairs.yaml --device esp12f-15.lan'
alias esp21dev='esphome run 0_DEV/esp12f-21_Underfloor.yaml --device esp12f-21.lan'
alias esp25dev='esphome run 0_DEV/esp12f-25_AquariumWindow.yaml --device esp12f-25.lan'
alias esp35dev='esphome run 0_DEV/esp32-35_Pump_Garage.yaml --device esp32-35.lan'
alias esp36dev='esphome run 0_DEV/esp32-36_Garage_Gate.yaml --device esp32-36.lan'
alias esp39dev='esphome run 0_DEV/esp32-39_Attic.yaml --device esp32-39.lan'
